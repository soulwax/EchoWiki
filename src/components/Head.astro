---
const { head } = Astro.locals.starlightRoute;
---

{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}

<script>
  import mermaid from 'mermaid';

  mermaid.initialize({
    startOnLoad: false,
    theme: 'base',
    securityLevel: 'strict',
    flowchart: {
      curve: 'basis',
      diagramPadding: 22,
      nodeSpacing: 48,
      rankSpacing: 58,
      htmlLabels: true,
    },
    sequence: {
      diagramMarginX: 24,
      diagramMarginY: 22,
      actorMargin: 38,
      width: 140,
      height: 42,
      boxMargin: 10,
      messageMargin: 40,
      messageAlign: 'center',
      mirrorActors: false,
      showSequenceNumbers: false,
      actorFontSize: 14,
      messageFontSize: 14,
      noteFontSize: 14,
      wrap: true,
      wrapPadding: 8,
    },
    state: {
      dividerMargin: 12,
      sizeUnit: 6,
    },
    quadrantChart: {
      chartWidth: 560,
      chartHeight: 420,
      quadrantPadding: 22,
    },
    themeVariables: {
      background: 'transparent',
      mainBkg: '#fff7ed',
      primaryColor: '#fff7ed',
      primaryTextColor: '#172026',
      primaryBorderColor: '#b8752d',
      secondaryColor: '#e8f4ef',
      secondaryBorderColor: '#3d7c72',
      tertiaryColor: '#eef4fb',
      tertiaryBorderColor: '#517aa5',
      lineColor: '#667c80',
      edgeLabelBackground: '#f8fafc',
      clusterBkg: '#f5faf8',
      clusterBorder: '#9eb8b2',
      noteBkgColor: '#fff3c7',
      noteBorderColor: '#c28a2c',
      noteTextColor: '#172026',
      actorBkg: '#fff7ed',
      actorBorder: '#b8752d',
      actorTextColor: '#e5f1ee',
      actorLineColor: '#8aa09f',
      signalColor: '#30434a',
      signalTextColor: '#e5f1ee',
      labelBoxBkgColor: '#f8fafc',
      labelBoxBorderColor: '#b8752d',
      labelTextColor: '#e5f1ee',
      fontFamily: 'Inter, ui-sans-serif, system-ui, sans-serif',
      fontSize: '15px',
    },
  });

  function diagramKind(source: string) {
    const trimmed = source.trimStart();
    if (trimmed.startsWith('sequenceDiagram')) return 'sequence';
    if (trimmed.startsWith('stateDiagram')) return 'state';
    if (trimmed.startsWith('quadrantChart')) return 'quadrant';
    if (trimmed.startsWith('flowchart')) return 'flowchart';
    return 'diagram';
  }

  function finishRenderedDiagrams() {
    document.querySelectorAll<SVGSVGElement>('svg[id^="mermaid-"]').forEach((svg) => {
      const legacyFrame = svg.closest<HTMLElement>('.mermaid-frame');
      const pre = legacyFrame?.parentElement ?? svg.closest<HTMLElement>('pre');
      if (!pre) return;

      if (legacyFrame) {
        legacyFrame.replaceWith(svg);
      }

      const surface = pre.closest<HTMLElement>('figure') ?? pre;
      const kind = pre.dataset.diagram ?? 'diagram';
      surface.classList.add('mermaid-surface');
      surface.dataset.diagram = kind;
      pre.classList.add('mermaid-rendered');
      svg.setAttribute('role', 'img');
      svg.setAttribute('focusable', 'false');
      svg.setAttribute('aria-label', `${kind} diagram`);

      const naturalWidth = svg.viewBox.baseVal.width;
      if (naturalWidth > 0) {
        svg.style.setProperty('--ew-mermaid-width', `${naturalWidth}px`);
      }
      if (kind === 'sequence' || naturalWidth > 600) {
        surface.dataset.layout = 'wide';
      }
      if ((kind === 'flowchart' || kind === 'state') && naturalWidth > 0 && naturalWidth <= 1400) {
        surface.dataset.fit = 'contain';
        svg.style.setProperty('--ew-mermaid-width', '100%');
        svg.style.setProperty('max-width', '100%');
      }
    });
  }

  async function renderMermaid() {
    const diagrams = document.querySelectorAll<HTMLElement>(
      'pre.mermaid:not([data-processed]), pre[data-language="mermaid"]:not([data-processed])',
    );
    if (!diagrams.length) {
      finishRenderedDiagrams();
      return;
    }
    for (const diagram of diagrams) {
      const copiedCode = diagram
        .closest('.expressive-code')
        ?.querySelector<HTMLButtonElement>('button[data-code]')
        ?.dataset.code;
      if (copiedCode) {
        diagram.textContent = copiedCode.replaceAll('\x7f', '\n');
      }
      const kind = diagramKind(diagram.textContent ?? '');
      diagram.dataset.diagram = kind;
    }
    await mermaid.run({ nodes: Array.from(diagrams) });
    finishRenderedDiagrams();
    requestAnimationFrame(finishRenderedDiagrams);
    window.setTimeout(finishRenderedDiagrams, 250);
  }

  window.addEventListener('load', renderMermaid);
  document.addEventListener('astro:after-swap', renderMermaid);
</script>
